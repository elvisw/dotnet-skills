{
  "mcpServers": {
    "binlog": {
      "type": "stdio",
      "command": "dotnet",
      "args": [
        "dnx",
        "Microsoft.AITools.BinlogMcp",
        "--yes",
        "--prerelease",
        "--add-source",
        "https://pkgs.dev.azure.com/dnceng/public/_packaging/dotnet-tools/nuget/v3/index.json"
      ],
      "tools": ["*"]
    }
  }
}
